# Supabase Auth (Google) + app data access - see supabase/README.md for
# how to set up the Google provider and where to find these values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key, used only by the standalone seed script
# (supabase/seed/load-seed.ts) - never read by the app at runtime.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider config — both can be configured; ACTIVE_AI_PROVIDER picks which
# one is used at runtime (see docs/06-ai-prompt-architecture.md)
ACTIVE_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
