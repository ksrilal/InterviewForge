# Single-user auth (see docs/13-deployment-plan.md)
AUTH_USERNAME=
# bcrypt hash of the password, never the plaintext. Generate locally with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
# IMPORTANT: bcrypt hashes contain literal $ characters, which Next.js's env
# loader (dotenv-expand) treats as variable interpolation even when quoted -
# escape every $ as \$ or the hash gets silently truncated. Example:
#   AUTH_PASSWORD_HASH=\$2b\$12\$VBYkmc10lagDwUE/kI2t2OxgK/c4nnjnDI4BvHIjAyPs7Nb7T8a4G
AUTH_PASSWORD_HASH=
# Random 32+ byte secret for HMAC session signing. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# Supabase (see supabase/README.md)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider config — both can be configured; ACTIVE_AI_PROVIDER picks which
# one is used at runtime (see docs/06-ai-prompt-architecture.md)
ACTIVE_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
