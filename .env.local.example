# Single-user auth (see docs/13-deployment-plan.md)
AUTH_USERNAME=
# bcrypt hash of the password, never the plaintext. Generate locally with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
# IMPORTANT: bcrypt hashes contain literal $ characters.
# - In THIS FILE (.env.local, read by Next.js's dotenv-expand loader), $X
#   is treated as variable interpolation even when quoted, silently
#   truncating the hash - escape every $ as \$ here:
#     AUTH_PASSWORD_HASH=\$2b\$12\$VBYkmc10lagDwUE/kI2t2OxgK/c4nnjnDI4BvHIjAyPs7Nb7T8a4G
# - In Vercel's (or any other host's) dashboard env var UI, values are
#   stored literally with NO parsing - paste the PLAIN hash there, with NO
#   backslashes, or the literal backslashes become part of the value:
#     AUTH_PASSWORD_HASH=$2b$12$VBYkmc10lagDwUE/kI2t2OxgK/c4nnjnDI4BvHIjAyPs7Nb7T8a4G
AUTH_PASSWORD_HASH=
# Random 32+ byte secret for HMAC session signing. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# Supabase (see supabase/README.md)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider config — both can be configured; ACTIVE_AI_PROVIDER picks which
# one is used at runtime (see docs/06-ai-prompt-architecture.md)
ACTIVE_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
